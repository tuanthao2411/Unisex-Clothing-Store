<%- include("../partials/header") %>
<div class="row justify-content-center">
  <div class="col-md-5 col-lg-4">
    <div class="surface-card p-4">
    <h3 class="section-title">Đăng ký tài khoản</h3>
    <p class="text-muted small">Tạo tài khoản mới để bắt đầu mua sắm.</p>
    <% if (error) { %>
    <div class="alert alert-danger"><%= error %></div>
    <% } %>
    <form method="POST" action="/register">
      <input class="form-control mb-3" type="text" name="fullName" placeholder="Họ tên" required />
      <input class="form-control mb-3" type="email" name="email" placeholder="Email" required />
      <input
        class="form-control mb-3"
        type="password"
        name="password"
        placeholder="Mật khẩu"
        required
      />
      <button class="btn btn-dark w-100">Đăng ký</button>
    </form>
    </div>
  </div>
</div>
<%- include("../partials/footer") %>
