<%- include("../partials/header") %>
<div class="row g-4">
  <div class="col-lg-8">
    <div class="surface-card p-4">
      <h3 class="section-title mb-3">Gio hang cua ban</h3>
      <% if (!items.length) { %>
      <p class="text-muted mb-0">Chua co san pham nao trong gio.</p>
      <% } else { %>
      <table class="table align-middle mb-0">
        <thead>
          <tr>
            <th>San pham</th>
            <th>So luong</th>
            <th>Gia</th>
            <th>Thanh tien</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% items.forEach((item) => { %>
          <tr>
            <td><%= item.Product.name %></td>
            <td><%= item.quantity %></td>
            <td><%= Number(item.Product.price).toLocaleString("vi-VN") %> VND</td>
            <td><%= Number(item.Product.price * item.quantity).toLocaleString("vi-VN") %> VND</td>
            <td>
              <form action="/shop/cart/remove/<%= item.id %>" method="POST">
                <button class="btn btn-sm btn-outline-danger">Xoa</button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      <% } %>
    </div>
  </div>
  <div class="col-lg-4">
    <div class="surface-card p-4">
      <h5 class="mb-3">Tóm tắt đơn hàng</h5>
      <div class="d-flex justify-content-between mb-2">
        <span>Tổng tiền</span>
        <strong><%= Number(total).toLocaleString("vi-VN") %> ₫</strong>
      </div>

      <hr class="my-3">

      <!-- Thanh toán QR (nổi bật) -->
      <a href="/shop/qr-checkout"
         class="btn w-100 mb-2 d-flex align-items-center justify-content-center gap-2 <%= !items.length ? 'disabled' : '' %>"
         style="background:linear-gradient(135deg,#1a1a2e,#374151);color:#fff;border-radius:12px;padding:12px;font-weight:700;text-decoration:none;"
         <%= !items.length ? 'tabindex="-1" aria-disabled="true"' : '' %>>
        <span style="font-size:1.1rem">📱</span>
        Thanh toán QR Code
      </a>

      <p class="text-muted" style="font-size:0.78rem;text-align:center;margin-bottom:0.75rem">
        Chuyển khoản ngân hàng qua mã QR — nhanh &amp; miễn phí
      </p>

      <div style="text-align:center;font-size:0.78rem;color:#aaa;margin-bottom:0.75rem">— hoặc —</div>

      <!-- Thanh toán Stripe -->
      <form action="/shop/checkout" method="POST">
        <button class="btn btn-outline-dark w-100" style="border-radius:12px;padding:10px;font-size:0.88rem;"
                <%= !items.length ? "disabled" : "" %>>
          💳 Thanh toán Stripe
        </button>
      </form>
    </div>
  </div>
</div>
<%- include("../partials/footer") %>
