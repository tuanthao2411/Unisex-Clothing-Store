<%- include("../partials/header") %>
<div class="row g-4">
  <div class="col-lg-8">
    <div class="surface-card p-4">
      <h3 class="section-title mb-3"><%= t("cart.title") %></h3>
      <% if (!items.length) { %>
      <p class="text-muted mb-0"><%= t("cart.empty") %></p>
      <% } else { %>
      <table class="table align-middle mb-0">
        <thead>
          <tr>
            <th><%= t("cart.product") %></th>
            <th><%= t("cart.variant") %></th>
            <th><%= t("cart.qty") %></th>
            <th><%= t("cart.price") %></th>
            <th><%= t("cart.subtotal") %></th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% items.forEach((item) => { %>
          <tr>
            <td><%= productName(item.Product) %></td>
            <td><%= item.variantLabel || "-" %></td>
            <td><%= item.quantity %></td>
            <td><%= Number(item.Product.price).toLocaleString("vi-VN") %> VND</td>
            <td><%= Number(item.Product.price * item.quantity).toLocaleString("vi-VN") %> VND</td>
            <td>
              <form action="/shop/cart/remove/<%= item.id %>" method="POST">
                <button class="btn btn-sm btn-outline-danger"><%= t("cart.remove") %></button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      <% } %>
    </div>
  </div>
  <div class="col-lg-4">
    <div class="surface-card p-4">
      <h5 class="mb-3">Tóm tắt đơn hàng</h5>
      <div class="d-flex justify-content-between mb-2">
        <span>Tổng tiền</span>
        <strong><%= Number(total).toLocaleString("vi-VN") %> ₫</strong>
      </div>

      <hr class="my-3">

      <!-- Checkout Buttons -->
      <% if (currentUser) { %>
        <!-- Thanh toán QR (nổi bật) -->
        <a href="/shop/qr-checkout"
           class="btn w-100 mb-2 d-flex align-items-center justify-content-center gap-2 <%= !items.length ? 'disabled' : '' %>"
           style="background:linear-gradient(135deg,#1a1a2e,#374151);color:#fff;border-radius:12px;padding:12px;font-weight:700;text-decoration:none;"
           <%= !items.length ? 'tabindex="-1" aria-disabled="true"' : '' %>>
          <span style="font-size:1.1rem">📱</span>
          Thanh toán QR Code
        </a>

        <p class="text-muted" style="font-size:0.78rem;text-align:center;margin-bottom:0.75rem">
          Chuyển khoản ngân hàng qua mã QR — nhanh &amp; miễn phí
        </p>

        <div style="text-align:center;font-size:0.78rem;color:#aaa;margin-bottom:0.75rem">— hoặc —</div>

        <!-- Thanh toán Stripe -->
        <form action="/shop/checkout" method="POST">
          <button class="btn btn-outline-dark w-100" style="border-radius:12px;padding:10px;font-size:0.88rem;"
                  <%= !items.length ? "disabled" : "" %>>
            💳 Thanh toán Stripe
          </button>
        </form>
      <% } else { %>
        <button class="btn btn-dark w-100 mb-2" style="border-radius:12px;padding:12px;font-weight:700;" data-bs-toggle="modal" data-bs-target="#loginModal" <%= !items.length ? 'disabled' : '' %>>
          Xác nhận đơn
        </button>
      <% } %>
    </div>
  </div>
</div>
<% if (!currentUser) { %>
<!-- Login Modal -->
<div class="modal fade" id="loginModal" tabindex="-1" aria-labelledby="loginModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header border-0 pb-0">
        <h5 class="modal-title" id="loginModalLabel">Đăng nhập để tiếp tục</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <form method="POST" action="/login">
          <input type="hidden" name="returnTo" value="/shop/cart" />
          <input class="form-control mb-3" type="email" name="email" placeholder="Email" required />
          <input
            class="form-control mb-3"
            type="password"
            name="password"
            placeholder="Mật khẩu"
            required
          />
          <button class="btn btn-dark w-100">Đăng nhập</button>
        </form>
        <div class="text-center mt-3">
          <span class="text-muted small">Chưa có tài khoản?</span>
          <a href="/register" class="small text-decoration-none">Đăng ký</a>
        </div>
      </div>
    </div>
  </div>
</div>
<% } %>
<%- include("../partials/footer") %>
