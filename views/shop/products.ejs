<%- include("../partials/header") %>
<section class="hero-clean">
  <div class="hero-overlay container">
    <h1>Define Your Style</h1>
    <p>Gender-fluid fashion for the modern individual</p>
    <a href="#collections" class="btn btn-light btn-lg px-4"><%= t("shop.heroExplore") %></a>
    <a href="/shop/all" class="btn btn-outline-light btn-lg px-4 mt-2"><%= t("shop.heroShopAll") %></a>
  </div>
</section>

<section class="container py-5">
  <h2 class="section-title center-title"><%= t("shop.shopByCategory") %></h2>
  <div class="row g-4 category-grid mt-1">
    <div class="col-md-4">
      <a href="/shop/products?category=Top#arrivals" class="category-card">
        <img
          src="https://images.unsplash.com/photo-1609763127387-7847990aab59?q=80&w=1587&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D?w=900&auto=format&fit=crop&q=60"
          alt="Top"
        />
        <span><%= t("category.top") %></span>
      </a>
    </div>
    <div class="col-md-4">
      <a href="/shop/products?category=Bottom#arrivals" class="category-card">
        <img
          src="https://images.unsplash.com/photo-1542272604-787c3835535d?w=900&auto=format&fit=crop&q=60"
          alt="Bottom"
        />
        <span><%= t("category.bottom") %></span>
      </a>
    </div>
    <div class="col-md-4">
      <a href="/shop/products?category=Jacket#arrivals" class="category-card">
        <img
          src="https://images.unsplash.com/photo-1551028719-00167b16eac5?q=80&w=1470&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D?w=900&auto=format&fit=crop&q=60"
          alt="Jacket"
        />
        <span><%= t("category.jacket") %></span>
      </a>
    </div>
  </div>
</section>

<section id="collections" class="container pb-5">
  <h2 class="section-title center-title"><%= t("shop.collectionsTitle") %></h2>
  <h5 class="mt-4 mb-3"><%= t("shop.fw2025") %></h5>
  <div class="row g-4">
    <% fw2025.forEach((product) => { %>
    <div class="col-md-6 col-lg-3">
      <div class="arrival-card">
        <img src="<%= product.imageUrl %>" class="arrival-image" alt="<%= productName(product) %>" />
        <div class="pt-3">
          <h6 class="mb-1"><%= productName(product) %></h6>
          <p class="mb-2 arrival-price"><%= Number(product.price).toLocaleString("vi-VN") %> <%= t("shop.currencySuffix") %></p>
          <form method="POST" action="/shop/cart/add/<%= product.id %>">
            <div class="d-flex gap-2 mb-2">
              <select class="form-select form-select-sm" name="size">
                <% product.sizeOptions.forEach((sz) => { %>
                <option value="<%= sz %>"><%= t("shop.size") %> <%= sz %></option>
                <% }) %>
              </select>
              <% if (product.colorOptionsParsed.length) { %>
              <select class="form-select form-select-sm" name="color">
                <% product.colorOptionsParsed.forEach((c) => { %>
                <option value="<%= colorLabel(c) %>"><%= colorLabel(c) %></option>
                <% }) %>
              </select>
              <% } %>
            </div>
            <button class="btn btn-sm btn-dark"><%= t("shop.addToCart") %></button>
          </form>
        </div>
      </div>
    </div>
    <% }) %>
  </div>

  <h5 class="mt-5 mb-3"><%= t("shop.ss2026") %></h5>
  <div class="row g-4">
    <% ss2026.forEach((product) => { %>
    <div class="col-md-6 col-lg-3">
      <div class="arrival-card">
        <img src="<%= product.imageUrl %>" class="arrival-image" alt="<%= productName(product) %>" />
        <div class="pt-3">
          <h6 class="mb-1"><%= productName(product) %></h6>
          <p class="mb-2 arrival-price"><%= Number(product.price).toLocaleString("vi-VN") %> <%= t("shop.currencySuffix") %></p>
          <form method="POST" action="/shop/cart/add/<%= product.id %>">
            <div class="d-flex gap-2 mb-2">
              <select class="form-select form-select-sm" name="size">
                <% product.sizeOptions.forEach((sz) => { %>
                <option value="<%= sz %>"><%= t("shop.size") %> <%= sz %></option>
                <% }) %>
              </select>
              <% if (product.colorOptionsParsed.length) { %>
              <select class="form-select form-select-sm" name="color">
                <% product.colorOptionsParsed.forEach((c) => { %>
                <option value="<%= colorLabel(c) %>"><%= colorLabel(c) %></option>
                <% }) %>
              </select>
              <% } %>
            </div>
            <button class="btn btn-sm btn-dark"><%= t("shop.addToCart") %></button>
          </form>
        </div>
      </div>
    </div>
    <% }) %>
  </div>
</section>

<section id="arrivals" class="container pb-5">
  <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h2 class="section-title mb-0">
      <% if (isShopAll) { %>
      <%= t("shop.shopAllTitle") %>
      <% } else { %>
      <%= typeof category !== "undefined" && category ? String(category).toUpperCase() + " • " : "" %><%= t("shop.newArrivals") %>
      <% } %>
    </h2>
    <% if (isShopAll) { %>
    <form class="d-flex align-items-center gap-2" method="GET" action="/shop/all">
      <label class="small text-muted"><%= t("shop.filterSort") %></label>
      <select class="form-select form-select-sm" style="min-width:160px" name="sort" onchange="this.form.submit()">
        <option value="latest" <%= sort === "latest" ? "selected" : "" %>><%= t("shop.sortLatest") %></option>
        <option value="oldest" <%= sort === "oldest" ? "selected" : "" %>><%= t("shop.sortOldest") %></option>
      </select>
    </form>
    <% } %>
  </div>
  <% if (isShopAll) { %>
  <p class="text-muted small"><%= t("shop.allProductsHint") %></p>
  <% } %>

  <div class="row g-4">
    <% products.forEach((product) => { %>
    <div class="col-md-6 col-lg-3">
      <div class="arrival-card">
        <img src="<%= product.imageUrl %>" class="arrival-image" alt="<%= product.name %>" />
        <div class="pt-3">
          <h6 class="mb-1"><%= productName(product) %></h6>
          <p class="mb-2 arrival-price"><%= Number(product.price).toLocaleString("vi-VN") %> <%= t("shop.currencySuffix") %></p>
          <form method="POST" action="/shop/cart/add/<%= product.id %>">
            <div class="d-flex gap-2 mb-2">
              <select class="form-select form-select-sm" name="size">
                <% product.sizeOptions.forEach((sz) => { %>
                <option value="<%= sz %>"><%= t("shop.size") %> <%= sz %></option>
                <% }) %>
              </select>
              <% if (product.colorOptionsParsed.length) { %>
              <select class="form-select form-select-sm" name="color">
                <% product.colorOptionsParsed.forEach((c) => { %>
                <option value="<%= colorLabel(c) %>"><%= colorLabel(c) %></option>
                <% }) %>
              </select>
              <% } %>
            </div>
            <button class="btn btn-sm btn-dark"><%= t("shop.addToCart") %></button>
          </form>
        </div>
      </div>
    </div>
    <% }) %>
  </div>
</section>
<%- include("../partials/footer") %>
