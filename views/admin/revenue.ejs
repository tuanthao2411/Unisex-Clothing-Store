<%- include("../partials/header") %>
<%
  let totalRevenue = 0;
  rows.forEach((row) => {
    totalRevenue += Number(row.get("totalRevenue")) || 0;
  });
%>
<div class="container py-4 admin-dashboard">
  <div class="row g-3 mb-4">
    <div class="col-md-4">
      <div class="surface-card stat-card p-4">
        <div class="stat-head">
          <span class="stat-icon stat-purple"><i class="bi bi-currency-dollar"></i></span>
        </div>
        <p class="stat-label">Tổng doanh thu</p>
        <h3><%= totalRevenue.toLocaleString("vi-VN") %> VND</h3>
      </div>
    </div>
    <div class="col-md-4">
      <div class="surface-card stat-card p-4">
        <div class="stat-head">
          <span class="stat-icon stat-blue"><i class="bi bi-calendar-week"></i></span>
        </div>
        <p class="stat-label">Số ngày có doanh thu</p>
        <h3><%= rows.length %></h3>
      </div>
    </div>
    <div class="col-md-4">
      <div class="surface-card stat-card p-4">
        <div class="stat-head">
          <span class="stat-icon stat-green"><i class="bi bi-bar-chart"></i></span>
        </div>
        <p class="stat-label">Trung bình mỗi ngày</p>
        <h3>
          <%= rows.length ? Math.round(totalRevenue / rows.length).toLocaleString("vi-VN") : 0 %> VND
        </h3>
      </div>
    </div>
  </div>

  <div class="surface-card p-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h4 class="admin-block-title mb-0">Báo cáo doanh thu theo ngày</h4>
      <a href="/admin/dashboard" class="btn btn-outline-dark btn-sm">Về dashboard</a>
    </div>
    <div class="table-responsive">
      <table class="table admin-table align-middle mb-0">
        <thead>
          <tr>
            <th>NGÀY</th>
            <th>DOANH THU</th>
            <th>TRẠNG THÁI</th>
          </tr>
        </thead>
        <tbody>
          <% rows.forEach((row) => { %>
          <tr>
            <td><%= row.get("date") %></td>
            <td><%= Number(row.get("totalRevenue")).toLocaleString("vi-VN") %> VND</td>
            <td><span class="status-instock">Hoàn tất</span></td>
          </tr>
          <% }) %>
          <% if (!rows.length) { %>
          <tr>
            <td colspan="3" class="text-center text-muted py-4">Chưa có dữ liệu doanh thu.</td>
          </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<%- include("../partials/footer") %>
