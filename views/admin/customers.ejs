<%- include("../partials/header") %>
<div class="container py-4 admin-dashboard">
  <div class="surface-card p-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
      <div>
        <h4 class="admin-block-title mb-1">Quản lý khách hàng</h4>
        <p class="text-muted mb-0">Theo dõi danh sách tài khoản khách hàng đã đăng ký.</p>
      </div>
      <span class="status-instock"><%= customers.length %> khách hàng</span>
    </div>

    <div class="table-responsive">
      <table class="table admin-table align-middle mb-0">
        <thead>
          <tr>
            <th>KHÁCH HÀNG</th>
            <th>EMAIL</th>
            <th>NGÀY TẠO</th>
            <th>TRẠNG THÁI</th>
          </tr>
        </thead>
        <tbody>
          <% customers.forEach((c) => { %>
          <tr>
            <td class="d-flex align-items-center gap-2">
              <span class="customer-avatar"><%= (c.fullName || "U").charAt(0).toUpperCase() %></span>
              <span><%= c.fullName %></span>
            </td>
            <td><%= c.email %></td>
            <td><%= new Date(c.createdAt).toLocaleString("vi-VN") %></td>
            <td><span class="status-instock">Active</span></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<%- include("../partials/footer") %>
