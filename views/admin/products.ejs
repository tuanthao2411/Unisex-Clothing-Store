<%- include("../partials/header") %>
<div class="container py-4 admin-dashboard">
  <div class="surface-card p-4 mb-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
      <div>
        <h4 class="admin-block-title mb-1">Quản lý sản phẩm</h4>
        <p class="text-muted mb-0">Cập nhật danh sách sản phẩm và hình ảnh cho storefront.</p>
      </div>
      <a href="/admin/products/new" class="btn btn-dark">Thêm sản phẩm</a>
    </div>

    <div class="table-responsive">
      <table class="table admin-table align-middle mb-0">
        <thead>
          <tr>
            <th>HINH ANH</th>
            <th>TÊN SẢN PHẨM</th>
            <th>GIÁ</th>
            <th>TỒN KHO</th>
            <th>TRẠNG THÁI</th>
            <th>THAO TÁC</th>
          </tr>
        </thead>
        <tbody>
          <% products.forEach((product) => { %>
          <tr>
            <td>
              <img src="<%= product.imageUrl %>" alt="<%= product.name %>" class="admin-product-thumb" />
            </td>
            <td>
              <p class="mb-1 fw-semibold"><%= product.name %></p>
              <small class="text-muted"><%= product.description.slice(0, 55) %><%= product.description.length > 55 ? "..." : "" %></small>
            </td>
            <td><%= Number(product.price).toLocaleString("vi-VN") %> VND</td>
            <td><%= product.stock %></td>
            <td>
              <span class="<%= product.stock > 0 ? 'status-instock' : 'status-outstock' %>">
                <%= product.stock > 0 ? "Còn hàng" : "Hết hàng" %>
              </span>
            </td>
            <td class="table-actions">
              <a href="/shop/products" title="Xem"><i class="bi bi-eye"></i></a>
              <a href="/admin/products/<%= product.id %>/edit" title="Sửa"><i class="bi bi-pencil-square"></i></a>
              <form action="/admin/products/<%= product.id %>?_method=DELETE" method="POST">
                <button type="submit" title="Xóa"><i class="bi bi-trash"></i></button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<%- include("../partials/footer") %>
