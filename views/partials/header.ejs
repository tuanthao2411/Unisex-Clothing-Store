<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
    />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <nav class="navbar navbar-expand-lg site-nav">
      <div class="container nav-shell">
        <a class="navbar-brand brand-logo" href="/shop/products">UNISEX</a>
        <div class="nav-center">
          <a class="nav-link" href="/shop/products">NEW IN</a>
          <a class="nav-link" href="/shop/products">COLLECTIONS</a>
          <a class="nav-link" href="/shop/products">ESSENTIALS</a>
          <% if (currentUser && currentUser.role === "admin") { %>
          <a class="nav-link about-pill" href="/admin/dashboard">ADMIN</a>
          <% } else { %>
          <a class="nav-link about-pill" href="/shop/products">ABOUT</a>
          <% } %>
        </div>
        <div class="nav-right">
          <a class="icon-link" href="/shop/products" aria-label="search"><i class="bi bi-search"></i></a>
          <% if (currentUser) { %>
          <% if (currentUser.role === "admin") { %>
          <form action="/logout" method="POST" class="d-inline">
            <button class="icon-btn" aria-label="logout"><i class="bi bi-box-arrow-right"></i></button>
          </form>
          <% } else { %>
          <a class="icon-link" href="/shop/products" aria-label="profile"><i class="bi bi-person"></i></a>
          <a class="icon-link" href="/shop/products" aria-label="wishlist"><i class="bi bi-heart"></i></a>
          <a class="icon-link bag-link" href="/shop/cart" aria-label="cart">
            <i class="bi bi-bag"></i>
            <span class="cart-badge"><%= typeof cartCount !== "undefined" ? cartCount : 0 %></span>
          </a>
          <form action="/logout" method="POST" class="d-inline ms-1">
            <button class="btn btn-sm btn-dark px-2 py-1">Dang xuat</button>
          </form>
          <% } %>
          <% } else { %>
          <a class="icon-link" href="/login" aria-label="profile"><i class="bi bi-person"></i></a>
          <a class="icon-link" href="/shop/products" aria-label="wishlist"><i class="bi bi-heart"></i></a>
          <a class="icon-link bag-link" href="/login" aria-label="cart">
            <i class="bi bi-bag"></i>
            <span class="cart-badge">0</span>
          </a>
          <a class="btn btn-sm btn-outline-dark ms-1" href="/register">Dang ky</a>
          <a class="btn btn-sm btn-dark ms-1" href="/login">Dang nhap</a>
          <% } %>
        </div>
      </div>
    </nav>
    <main class="main-shell">
